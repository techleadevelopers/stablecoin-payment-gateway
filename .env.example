# ============================================
# 🚀 Database
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/database"

# ============================================
# 🔐 Security & Keys
# ============================================
PRIVATE_KEY="your_private_key_here"
LGPD_SECRET="your_lgpd_secret_here"
WEBHOOK_SECRET="your_webhook_secret_here"
PIX_WEBHOOK_SECRET="your_pix_webhook_secret_here"
MOBILE_WALLET_ENCRYPTION_SECRET="your_32_plus_chars_mobile_wallet_key_secret"
# Public owner wallet shown in the mobile app for paulo@chainfx.com.
OWNER_MOBILE_WALLET_ADDRESS="0xb6B00781a81ee10E77f9417d24531FB2529955aA"
# Secret manager / local import only. Never commit a real private key.
OWNER_MOBILE_WALLET_PRIVATE_KEY=""

# ============================================
# 📧 SMTP - Email Configuration
# ============================================
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
SMTP_USER="your_email@domain.com"
SMTP_PASS="your_smtp_password"
SMTP_SECURE="true"
SMTP_FROM_EMAIL="noreply@domain.com"
SMTP_FROM_NAME="Your App Name"

# ============================================
# 👤 Admin Bootstrap
# ============================================
ADMIN_BOOTSTRAP_EMAIL="admin@domain.com"
ADMIN_BOOTSTRAP_PASSWORD="your_secure_password"
# Optional second factor for the web admin console. Send as X-Admin-Console-Key.
ADMIN_CONSOLE_KEY="your_private_console_keyword"

# ============================================
# 🌐 Application
# ============================================
PORT="8080"
APP_ENV=development  # production, development, test
ALLOW_SIMULATIONS=false
GODEBUG=x509negativeserial=1

# ============================================
# 💳 Efí Pix - PRODUCTION
# ============================================
EFI_CLIENT_ID="your_client_id"
EFI_CLIENT_SECRET="your_client_secret"
EFI_PIX_KEY="your_pix_key"
EFI_API_BASE_URL=https://pix.api.efipay.com.br
EFI_CERTIFICATE_PATH="secrets/efi-production.p12"
EFI_CERTIFICATE_KEY_PATH=""
EFI_CERTIFICATE_PASSWORD=""
EFI_CERTIFICATE_P12_BASE64="your_base64_certificate"
EFI_PIX_FEE_BPS=119

# ============================================
# 💳 Efí Pix - HOMOLOGATION (Testing)
# ============================================
# EFI_CLIENT_ID="Client_Id_homolog"
# EFI_CLIENT_SECRET="Client_Secret_homolog"
# EFI_API_BASE_URL=https://pix-h.api.efipay.com.br
# EFI_CERTIFICATE_PATH="secrets/efi-homolog.p12"

# ============================================
# 🤖 OpenAI - AI Agents
# ============================================
OPENAI_API_KEY="sk-proj-your_openai_key"
OPENAI_MODEL="gpt-4"  # gpt-4, gpt-4o, gpt-3.5-turbo
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# ============================================
# ⛓️ Blockchain - BSC
# ============================================
SIGNER_URL=https://your-signer-url.com
SIGNER_NETWORK=bsc
SIGNER_HMAC_SECRET="your_hmac_secret"
BSC_RPC_URLS=https://bsc-mainnet.core.chainstack.com/your_key
BSC_CHAIN_ID=56
RPC1=https://bsc-mainnet.core.chainstack.com/your_key
RPC2=https://shared.us-east-1.getblock.io/your_key
RPC3=https://shared.us-east-1.getblock.io/your_key
RPC4=https://shared.us-east-1.getblock.io/your_key
RPCN=https://shared.us-east-1.getblock.io/your_key
BSC_USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
TREASURY_HOT="0xYourTreasuryHotEVMAddress"
# Optional only. Buy/Sell core works with direct wallet transfers and does not require Swappy contracts.
BSC_TREASURY_CONTRACT=

# ============================================
# ⛓️ Blockchain - Polygon
# ============================================
POLYGON_RPC_URLS=https://polygon-mainnet.core.chainstack.com/your_key
POLYGON_CHAIN_ID=137
POLYGON_USDT_CONTRACT=0xc2132D05D31c914a87C6611C10748AEb04B58e8F
POLYGON_TREASURY_CONTRACT=

# ============================================
# Blockchain - EVM multi-chain
# ============================================
BASE_RPC_URLS=https://base-mainnet.g.alchemy.com/v2/your_key
BASE_CHAIN_ID=8453
BASE_USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
ARBITRUM_RPC_URLS=https://arb-mainnet.g.alchemy.com/v2/your_key
ARBITRUM_CHAIN_ID=42161
ARBITRUM_USDC_CONTRACT=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
ETHEREUM_RPC_URLS=https://eth-mainnet.g.alchemy.com/v2/your_key
ETHEREUM_CHAIN_ID=1
ETHEREUM_USDC_CONTRACT=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# ============================================
# Blockchain - Solana
# ============================================
SOLANA_ENABLED=true
SOLANA_CLUSTER=mainnet
SOLANA_RPC_URLS=https://api.mainnet-beta.solana.com
SOLANA_WITHDRAWALS_ENABLED=false
SOLANA_SCAN_INTERVAL_SEC=30
SOLANA_TX_SCAN_INTERVAL_SEC=20
SOLANA_MIN_CONFIRMATIONS=1
SOLANA_MAX_SEND_LAMPORTS=0

# Mobile staging/testnet example for real wallet transfer tests.
# BSC_RPC_URLS=https://data-seed-prebsc-1-s1.bnbchain.org:8545
# BSC_CHAIN_ID=97
# BSC_USDT_CONTRACT=<endereco_real_do_MockUSDT3009_deployado_na_BSC_testnet>
# POLYGON_RPC_URLS=https://polygon-amoy-bor-rpc.publicnode.com
# POLYGON_CHAIN_ID=80002
# POLYGON_USDT_CONTRACT=<endereco_real_do_MockUSDT3009_deployado_na_Polygon_Amoy>

# ============================================
# 💰 Fees Configuration
# ============================================
FEE_BPS=200
FEE_FIXED_USD=0
FEE_PER_USDT_USD=0.03

# ============================================
# 🛡️ Custody Guard
# ============================================
CUSTODY_GUARD_ENABLED=true
CUSTODY_GUARD_POLL_MS=1500
CUSTODY_MODE=paper
CUSTODY_TRUSTED_DELEGATES=
CUSTODY_ALLOWED_SELECTORS=
CUSTODY_PROTECTED_WALLETS=0xYourTreasuryHotEVMAddress

# ============================================
# 🔑 API Keys
# ============================================
CHAINFX_TEST_PUBLIC_KEYS="pk_test_your_key"
CHAINFX_TEST_SECRET_KEYS="sk_test_your_key"
CHAINFX_LIVE_PUBLIC_KEYS="pk_live_your_key"
CHAINFX_LIVE_SECRET_KEYS="sk_live_your_key"
CHAINFX_REQUIRE_API_KEY=true

# ============================================
# 💱 Sell USDT -> PIX BRL
# ============================================
SELL_WALLET_ADDRESS="0xYourSellWallet"
SELL_PAYOUT_MODE=manual
SELL_RATE_BPS=8772
SELL_USDT_BRL_RATE=0

# ============================================
# 🧪 E2E Tests
# ============================================
RUN_E2E_TESTS=false
RUN_TESTNET_PAYMENT_TESTS=false
RUN_LIVE_PAYMENT_TESTS=false
E2E_BASE_URL=http://localhost:8080
E2E_API_KEY="your_test_api_key"
E2E_AGENT_WALLET=0x0000000000000000000000000000000000001001
E2E_PAYER_WALLET=0x0000000000000000000000000000000000001001
E2E_DEST_WALLET=0x0000000000000000000000000000000000001001
E2E_PAYMENT_ASSET=USDT
E2E_PIX_KEY="your_pix_key"
E2E_TEST_WALLET_PRIVATE_KEY=
E2E_TEST_TX_HASH=
E2E_TEST_LOG_INDEX=0
LIVE_PAYMENT_MAX_USD=1.00
LIVE_PAYMENT_CONFIRMATION_REQUIRED=true

# ============================================
# 🤝 M2M Agent Payments
# ============================================
M2M_PIX_FEE_BPS=1000
M2M_CREDIT_FEE_BPS=1900
M2M_DEPOSIT_TOLERANCE_PCT=0.005
M2M_MAX_DAILY_OUTFLOW_BRL=50000
# Optional pool for concurrent pending M2M intents. If empty, TREASURY_HOT is used.
M2M_DEPOSIT_ADDRESSES="0xYourM2MDepositAddress1,0xYourM2MDepositAddress2"

# ============================================
# ChainFX Tap NFC Closed-Loop
# No Visa/Mastercard network: ChainFX terminal -> ChainFX API -> USDT hold/capture -> Efi/PIX merchant settlement.
# ============================================
NFC_ENABLED=true
NFC_TOKEN_SECRET="your_nfc_token_secret"
NFC_TOKEN_TTL_SEC=120
NFC_HOLD_TTL_SEC=900
NFC_MAX_AMOUNT_BRL=500
NFC_PRICE_MAX_AGE_SEC=180
NFC_FEE_BPS=400
NFC_LIQUIDITY_POLICY_ENABLED=false
NFC_EFI_MIN_BUFFER_BRL=0
NFC_EFI_BALANCE_BRL=0
# Optional bootstrap for ChainFX Tap terminals.
# Format: merchant_id:terminal_id:terminal_api_key[:merchant_display_name]
# Store the real terminal_api_key only in Railway/.env; the backend stores SHA-256 hash in Postgres.
NFC_TERMINALS="merchant_demo:terminal_01:replace_with_strong_terminal_key:Demo Merchant"

# ============================================
# 🔌 Optional Capabilities
# ============================================
CAPABILITY_OCR_URL=
CAPABILITY_OCR_API_KEY=

# MOBILE
MOBILE_JWT_SECRET="your_mobile_jwt_secret"
MOBILE_REFRESH_SECRET="your_mobile_refresh_secret"
# Redis / distributed rate limit
REDIS_URL=
RATE_LIMIT_BACKEND=redis
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
ORDER_RATE_LIMIT_WINDOW_MS=60000
ORDER_RATE_LIMIT_MAX=20

# Signer nonce replay protection
NONCE_STORE_TYPE=redis
NONCE_TTL_SECONDS=300

# ============================================
# Bitcoin BTC Real Mobile Rail
# Keep withdrawals disabled and emergency lockdown enabled until XPUB, encrypted
# signing seed/xpriv and provider are validated in staging.
# ============================================
BTC_ENABLED=false
BTC_NETWORK=testnet
BTC_PROVIDER_TYPE=mempool
BTC_API_URL=
BTC_API_TOKEN=
BTC_XPUB=
BTC_ENCRYPTED_SEED=
BTC_ENCRYPTION_KEY=
BTC_MIN_CONFIRMATIONS=3
BTC_DEPOSIT_SCAN_INTERVAL=30s
BTC_TRANSACTION_SCAN_INTERVAL=30s
BTC_FEE_POLICY=normal
BTC_FEE_TARGET_BLOCKS=3
BTC_MIN_FEE_RATE_SAT_VB=1
BTC_MAX_FEE_RATE_SAT_VB=200
BTC_DUST_LIMIT_SATS=546
BTC_MAX_SEND_SATS=0
BTC_DAILY_SEND_LIMIT_SATS=0
BTC_HOT_WALLET_RESERVE_SATS=0
BTC_WITHDRAWALS_ENABLED=false
BTC_EMERGENCY_LOCKDOWN=true

LIQUIDITY_ROUTER_ENABLED=false
LIQUIDITY_PROVIDER_URLS=chainfx=https://a....
LIQUIDITY_PROVIDER_API_KEY=Aj6zzV7qj...
LIQUIDITY_QUOTE_TIMEOUT_MS=2500
SUPPORTED_NETWORKS=BSC,POLYGON,BASE,ARBITRUM,ETHEREUM,BITCOIN,SOLANA
LIQUIDITY_ALLOWED_PAIRS=USDT:BSC:0x55d398326f99059fF775485246999027B3197955:18,USDT:POLYGON:0xc2132D05D31c914a87C6611C10748AEb04B58e8F:6,BTC:BITCOIN::8,BNB:BSC::18,SOL:SOLANA::9,ETH:BSC:0x2170Ed0880ac9A755fd29B2688956BD959F933F8:18,ETH:POLYGON:0x7ceB23fD6bC0adD59E62ac25578270cFf1b9f619:18,USDC:BASE:0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913:6,ETH:BASE::18,USDC:ARBITRUM:0xaf88d065e77c8cC2239327C5EDb3A432268e5831:6,ETH:ARBITRUM::18,USDC:ETHEREUM:0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48:6,ETH:ETHEREUM::18,LINK:BSC:0xF8A0BF9cF54Bb92F17374d9e9A321E6a111a51bD:18,LINK:POLYGON:0x53E0bca35eC356BD5ddDFebbd1Fc0fD03FaBad39:18,AVAX:BSC:0x1CE0c2827e2eF14D5C4f29a091d735A204794041:18
LIQUIDITY_ALLOWED_ASSETS=USDT,BTC,BNB,SOL,ETH,USDC,LINK,AVAX
LIQUIDITY_ALLOWED_NETWORKS=BSC,POLYGON,BASE,ARBITRUM,ETHEREUM,BITCOIN,SOLANA
LIQUIDITY_ROUTER_HOT_WALLET_FIRST_ASSETS=USDT
