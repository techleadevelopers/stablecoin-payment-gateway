{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.techleadevelopers/chainfx-mcp",
  "title": "ChainFX Capability Network",
  "description": "Capability network for AI agents with stablecoin-funded real-world payments.",
  "websiteUrl": "https://www.chainfx.store",
  "repository": {
    "url": "https://github.com/chainfx/payment-gateway",
    "source": "github"
  },
  "version": "1.2.1",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://stablecoin-payment-gateway-production-3ee2.up.railway.app/mcp/initialize",
      "headers": [
        {
          "name": "Authorization",
          "description": "Optional for discovery. Required as Bearer ChainFX API key for purchases, execution, private status and M2M payments.",
          "isRequired": false,
          "isSecret": true
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "tool": "mcp-publisher",
      "version": "1.2.1",
      "build_info": {
        "service": "chainfx-mcp",
        "public_title": "ChainFX Capability Network MCP",
        "release_channel": "production",
        "timestamp": "2026-07-11T00:00:00Z"
      }
    },
    "store.chainfx/product": {
      "category": "capability-marketplace",
      "positioning": "economic infrastructure for autonomous agents to buy capabilities, route execution and settle real-world payments with stablecoins",
      "product_summary": "ChainFX Capability Network lets agents discover and buy digital capabilities, execute metered services, trade stablecoins and request real-world fiat payments funded by USDT.",
      "primary_flow": [
        "discover_capability",
        "purchase_capability",
        "pay_stablecoin",
        "receive_access_grant",
        "execute_capability",
        "meter_usage",
        "settle_provider"
      ],
      "agent_payments_flow": [
        "create_payment_intent",
        "quote_required_usdt",
        "deposit_usdt_to_unique_payment_address",
        "match_deposit_by_address",
        "chainfx_pays_pix_payment_link_or_card_bill",
        "attach_settlement_receipt",
        "poll_payment_intent_status"
      ],
      "featured_tools": [
        "searchCapabilities",
        "listCapabilities",
        "getCapability",
        "getCapabilityContract",
        "purchaseCapability",
        "getPurchase",
        "executeCapability",
        "chooseRoute",
        "getUsage",
        "listAssets",
        "quote",
        "trade",
        "settlementStatus",
        "createPaymentIntent",
        "getPaymentIntent",
        "listAgentPaymentIntents"
      ],
      "featured_capabilities": [
        "semantic_memory",
        "llm_chat",
        "document_ocr",
        "payments_fx",
        "agent_payments",
        "capability_discovery",
        "aml_screening"
      ],
      "agent_payments": {
        "status": "available",
        "capability_id": "agent_payments",
        "description": "Agents can pay real-world PIX recipients, payment links or card bills by funding an intent with BSC USDT. ChainFX performs the fiat payment after deposit confirmation and returns settled status plus receipt.",
        "types": [
          "pix",
          "credit_card"
        ],
        "destination_fields": {
          "pix": [
            "pix_key"
          ],
          "credit_card": [
            "payment_link",
            "barcode",
            "beneficiary_name",
            "due_date"
          ]
        },
        "funding_asset": "USDT",
        "funding_network": "BSC",
        "rest_endpoints": {
          "create": "https://stablecoin-payment-gateway-production-3ee2.up.railway.app/agent/v1/pay",
          "status": "https://stablecoin-payment-gateway-production-3ee2.up.railway.app/agent/v1/pay/{id}"
        },
        "mcp_tools": [
          "createPaymentIntent",
          "getPaymentIntent",
          "listAgentPaymentIntents"
        ],
        "settlement_policy": "ChainFX pays the fiat destination only after the agent-funded USDT deposit is confirmed.",
        "agent_result": "Agents poll getPaymentIntent and receive lifecycle status, deposit transaction, settlement status and settlement_receipt_url or settlement_receipt_note when paid."
      },
      "payments": {
        "assets": [
          "USDT",
          "USDC"
        ],
        "networks": [
          "BSC"
        ],
        "settlement": "stablecoin"
      },
      "production_readiness": {
        "catalog": true,
        "metering_billing_settlement": true,
        "mock_dev_fallback": false,
        "seed_fixtures": false
      },
      "docs": {
        "openapi": "https://stablecoin-payment-gateway-production-3ee2.up.railway.app/openapi.json",
        "agent_capabilities": "https://stablecoin-payment-gateway-production-3ee2.up.railway.app/agent/v1/capabilities",
        "well_known": "https://stablecoin-payment-gateway-production-3ee2.up.railway.app/.well-known/ai-services.json"
      }
    }
  }
}
